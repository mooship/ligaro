---
import readingTime from "reading-time";
import Layout from "../../layouts/Layout.astro";
import { BLOG_DESCRIPTION, getBlogPosts, getPostSlug } from "../../lib/blog";

const posts = await getBlogPosts();
const postsWithMeta = posts.map((post) => ({
  post,
  readingTime: readingTime(post.body ?? "").text,
}));
---

<Layout
  title="Blog — Timothy Brits"
  description={BLOG_DESCRIPTION}
  type="website"
>
  <main id="main-content" tabindex="-1">
    <h1>Blog</h1>
    {
      postsWithMeta.length === 0 ? (
        <p class="empty">No posts yet.</p>
      ) : (
        <ul>
          {postsWithMeta.map(({ post, readingTime }) => (
            <li>
              <a href={`/blog/${getPostSlug(post.id)}`}>
                <span>{post.data.title}</span>
              </a>
              <p class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-ZA", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                {readingTime && <span> · {readingTime}</span>}
              </p>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))}
        </ul>
      )
    }
    <a href="/" class="back-link">
      <span>&larr; Back</span>
    </a>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  h1 {
    text-align: left;
    color: var(--color-heading);
    margin: 0 0 1.5rem 0;
    font-weight: 700;
    font-size: 2.5rem;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
  }

  li {
    margin-bottom: 1.5rem;
  }

  a {
    font-size: 1rem;
    font-weight: 500;
  }

  .post-meta {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin: 0.25rem 0 0 0;
    letter-spacing: 0.01em;
  }

  .post-desc {
    margin: 0.25rem 0 0 0;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.47;
  }

  .empty {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }

  .back-link {
    margin-top: 1rem;
  }
</style>
