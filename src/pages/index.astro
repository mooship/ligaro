---
import Layout from "../layouts/Layout.astro";
import { Content as IntroContent } from "../sections/intro.md";
import { Content as PersonalContent } from "../sections/personal.md";
import { Content as WritingContent } from "../sections/writing.md";
import { Content as OpenSourceContent } from "../sections/opensource.md";
import { Content as SupportContent } from "../sections/support.md";
import { getBlogPosts, getPostSlug } from "../lib/blog";

const recentPosts = (await getBlogPosts()).slice(0, 5);
---

<Layout
  title="Timothy Brits"
  description="Links and ways to connect with Timothy Brits - social profiles, and more."
  type="website"
>
  <main id="main-content" aria-label="Content" tabindex="-1">
    <IntroContent />
    {
      recentPosts.length > 0 && (
        <div class="section-blog">
          <h2>Blog</h2>
          <ul class="recent-posts">
            {recentPosts.map((post) => (
              <li>
                <a href={`/blog/${getPostSlug(post.id)}`}>
                  <i class="ri-pencil-line" aria-hidden="true" />
                  <span>{post.data.title}</span>
                </a>
                <time
                  class="post-date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {post.data.pubDate.toLocaleDateString("en-ZA", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </li>
            ))}
          </ul>
          <a href="/blog" class="all-posts">
            <i class="ri-arrow-right-s-line" aria-hidden="true" />
            <span>All posts</span>
          </a>
        </div>
      )
    }
    <OpenSourceContent />
    <WritingContent />
    <SupportContent />
    <PersonalContent />
  </main>
</Layout>

<style>
  main {
    margin: auto;
  }

  :global(main > p:first-child) {
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
    line-height: 1.6;
    text-wrap: balance;
  }

  :global(.section-blog),
  :global(.section-personal),
  :global(.section-writing),
  :global(.section-opensource),
  :global(.section-support) {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  :global(h2) {
    color: var(--color-heading);
    margin: 0 0 0.75rem 0;
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  :global(h2 + p) {
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    font-size: 0.9rem;
    margin-top: -0.5rem;
  }

  :global(ul) {
    list-style: none;
    padding: 0;
    margin-bottom: 0;
  }

  :global(li) {
    margin-bottom: 0.6rem;
  }

  :global(a) {
    font-size: 0.95rem;
  }

  :global(li i) {
    margin-right: 0.5rem;
  }

  :global(.project-desc) {
    margin: 0.15rem 0 0 1.6rem;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .section-blog {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .section-blog h2 {
    color: var(--color-heading);
    margin: 0 0 0.75rem 0;
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .recent-posts {
    list-style: none;
    padding: 0;
    margin: 0 0 0.5rem 0;
  }

  .recent-posts li {
    margin-bottom: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .post-date {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    margin-left: 1.6rem;
  }

  .all-posts {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
  }
</style>
