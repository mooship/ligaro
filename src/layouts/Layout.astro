---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import ThemeToggle from "../components/ThemeToggle.astro";
import EasterEggs from "../components/EasterEggs.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  robots?: string;
  type?: "website" | "article";
  datePublished?: Date;
  dateModified?: Date;
}

const {
  title,
  description,
  image,
  canonical: canonicalProp,
  robots = "index,follow",
  type = "website",
  datePublished,
  dateModified,
} = Astro.props as Props;

const url = Astro.url;
const pathname = url.pathname;
const canonical = canonicalProp ?? url.origin + url.pathname;
const schemaType = type === "article" ? "Article" : "WebSite";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": schemaType,
  name: title,
  ...(canonical ? { url: canonical } : {}),
  ...(description ? { description } : {}),
  ...(image ? { image } : {}),
  ...(type === "article"
    ? {
        author: { "@type": "Person", name: "Timothy Brits" },
        ...(datePublished
          ? { datePublished: datePublished.toISOString() }
          : {}),
        ...(dateModified ? { dateModified: dateModified.toISOString() } : {}),
      }
    : {}),
};
---

<!doctype html>
<html lang="en">
  <head>
    <Font cssVariable="--font-mono" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, viewport-fit=cover" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <meta name="robots" content={robots} />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#000000"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Timothy Brits — RSS"
      href="/rss.xml"
    />
    <link
      rel="alternate"
      type="application/atom+xml"
      title="Timothy Brits — Atom"
      href="/atom.xml"
    />
    <link
      rel="alternate"
      type="application/feed+json"
      title="Timothy Brits — JSON Feed"
      href="/feed.json"
    />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function () {
        const t = localStorage.getItem("theme");
        if (t === "dark" || t === "light") {
          document.documentElement.dataset.theme = t;
        } else {
          document.documentElement.dataset.theme = globalThis.matchMedia(
            "(prefers-color-scheme: dark)"
          ).matches
            ? "dark"
            : "light";
        }
      })();
    </script>
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={type} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content="Timothy Brits" />
    {image && <meta property="og:image" content={image} />}
    <meta
      name="twitter:card"
      content={image ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}
    {
      canonical && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header>
      <a href="/">Timothy Brits</a>
      <nav aria-label="Main">
        <a
          href="/blog"
          aria-current={pathname.startsWith("/blog") ? "page" : undefined}
          >Blog</a
        >
        <a href="/now" aria-current={pathname === "/now" ? "page" : undefined}
          >Now</a
        >
        <a href="/uses" aria-current={pathname === "/uses" ? "page" : undefined}
          >Uses</a
        >
        <ThemeToggle />
      </nav>
    </header>
    <div transition:animate="fade">
      <slot />
    </div>
    <EasterEggs />
    <footer>
      <nav class="feed-links" aria-label="Feed subscriptions">
        <span>Subscribe:</span>
        <a href="/atom.xml">Atom</a>
        <a href="/rss.xml">RSS</a>
        <a href="/feed.json">JSON Feed</a>
      </nav>
    </footer>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .skip-link:focus-visible {
    position: fixed;
    top: 1rem;
    left: 1rem;
    width: auto;
    height: auto;
    overflow: visible;
    padding: 0.5rem 1rem;
    background: var(--system-background);
    color: var(--link);
    border: 2px solid var(--link);
    border-radius: 4px;
    font-size: 0.9rem;
    z-index: 9999;
    text-decoration: none;
  }

  @keyframes rainbow-shimmer {
    from {
      background-position-x: 0%;
    }
    to {
      background-position-x: 200%;
    }
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
    border-bottom: none;
    background-image: var(--rainbow-gradient);
    background-size: 200% 4px;
    background-repeat: no-repeat;
    background-position: 0% bottom;
    animation: rainbow-shimmer 8s ease-in-out infinite alternate;
  }

  header a:first-child {
    font-weight: 400;
    font-size: 1.2rem;
    color: var(--label);
    letter-spacing: -0.01em;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  nav a {
    font-weight: 500;
    font-size: 0.9375rem;
    padding: 0.75rem 0.5rem;
    color: var(--secondary-label);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--label);
    text-decoration: none;
  }

  nav a[aria-current="page"],
  nav a[aria-current="page"]:hover {
    color: var(--label);
    text-decoration: underline;
    text-decoration-color: var(--color-apple-blue);
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: none;
    background-image: var(--rainbow-gradient);
    background-size: 200% 4px;
    background-repeat: no-repeat;
    background-position: 0% top;
    animation: rainbow-shimmer 8s ease-in-out infinite alternate;
    font-size: 0.8125rem;
    color: var(--secondary-label);
  }

  .feed-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .feed-links a {
    padding: 0.75rem 0.5rem;
  }

  footer a {
    color: var(--link);
  }

  footer a:hover {
    color: var(--link-hover);
  }
</style>
