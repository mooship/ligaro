---
import Layout from "../layouts/Layout.astro";
import { Content as IntroContent } from "../sections/intro.md";
import { Content as PersonalContent } from "../sections/personal.md";
import { Content as WritingContent } from "../sections/writing.md";
import { Content as SupportContent } from "../sections/support.md";
---

<Layout
  title="Timothy Brits"
  description="Links and ways to connect with Timothy Brits - social profiles, and more."
  type="website"
>
  <main aria-label="Content">
    <IntroContent />
    <PersonalContent />
    <WritingContent />
    <SupportContent />
  </main>
</Layout>

<style>
  main {
    margin: auto;
  }

  :global(h1) {
    text-align: center;
    color: var(--color-heading);
    margin: 0 0 0.5rem 0;
    font-weight: 500;
    font-size: 1.75rem;
  }

  :global(h1 + p) {
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  :global(.section-personal),
  :global(.section-writing),
  :global(.section-support) {
    margin-top: 2.5rem;
  }

  :global(h2) {
    text-align: left;
    color: var(--color-heading);
    margin: 0 0 0.75rem 0;
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  :global(h2 + p) {
    text-align: left;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    font-size: 0.9rem;
    margin-top: -0.5rem;
  }

  :global(ul) {
    list-style-type: none;
    padding: 0;
    margin-bottom: 0;
  }

  :global(li) {
    margin-bottom: 0.6rem;
  }

  :global(a) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-link);
    text-decoration: none;
    transition: color 0.2s ease;
    font-size: 0.95rem;
  }

  :global(a:hover) {
    color: var(--color-link-hover);
  }

  :global(a i) {
    font-size: 1.1em;
    flex: 0 0 auto;
  }

  :global(a span) {
    flex-grow: 1;
  }
</style>
