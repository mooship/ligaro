---
import { render } from "astro:content";
import PostListItem from "../../../components/PostListItem.astro";
import Layout from "../../../layouts/Layout.astro";
import { getAllTags, getBlogPosts, getPostsByTag } from "../../../lib/blog";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const tags = getAllTags(posts);

  return tags.map((tag) => ({
    params: { tag },
    props: { tag, posts: getPostsByTag(posts, tag) },
  }));
}

const { tag, posts } = Astro.props;
const postsWithMeta = await Promise.all(
  posts.map(async (post: Awaited<ReturnType<typeof getBlogPosts>>[number]) => {
    const { remarkPluginFrontmatter } = await render(post);
    return {
      post,
      readingTime: remarkPluginFrontmatter?.readingTime as string | undefined,
    };
  })
);
---

<Layout
  title={`Posts tagged "${tag}" — Timothy Brits`}
  description={`Blog posts tagged "${tag}".`}
  type="website"
>
  <main id="main-content" tabindex="-1">
    <a href="/blog" class="back-link">
      <span aria-hidden="true">&larr;</span> All posts
    </a>
    <h1>Tagged &ldquo;{tag}&rdquo;</h1>
    <ul>
      {
        postsWithMeta.map(({ post, readingTime }) => (
          <PostListItem post={post} readingTime={readingTime} />
        ))
      }
    </ul>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  h1 {
    text-align: left;
    color: var(--color-heading);
    margin: 0 0 1.5rem 0;
    font-weight: 400;
    font-size: 3rem;
    letter-spacing: -0.01em;
    line-height: 1.08;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
  }
</style>
