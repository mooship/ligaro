---
import Layout from "../layouts/Layout.astro";
import { Content as IntroContent } from "../sections/intro.md";
import { Content as PersonalContent } from "../sections/personal.md";
import { Content as WritingContent } from "../sections/writing.md";
import { Content as OpenSourceContent } from "../sections/opensource.md";
import { Content as SupportContent } from "../sections/support.md";
import { getBlogPosts, getPostSlug } from "../lib/blog";

const posts = await getBlogPosts();
const recentPosts = posts.slice(0, 5);
---

<Layout
  title="Timothy Brits"
  description="Links and ways to connect with Timothy Brits - social profiles, and more."
  type="website"
>
  <main id="main-content" aria-label="Content" tabindex="-1">
    <h1 class="visually-hidden">Timothy Brits</h1>
    <IntroContent />
    {
      recentPosts.length > 0 && (
        <div class="section-blog">
          <h2>Blog</h2>
          <ul class="recent-posts">
            {recentPosts.map((post) => (
              <li>
                <a href={`/blog/${getPostSlug(post.id)}`}>
                  <span>{post.data.title}</span>
                </a>
                <time
                  class="post-date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {post.data.pubDate.toLocaleDateString("en-ZA", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </li>
            ))}
          </ul>
          <a href="/blog" class="all-posts">
            <span>All posts &rarr;</span>
          </a>
        </div>
      )
    }
    <OpenSourceContent />
    <WritingContent />
    <SupportContent />
    <PersonalContent />
  </main>
</Layout>

<style>
  main {
    margin: auto;
  }

  :global(main > p:first-child) {
    font-family: var(--font-serif), Georgia, "Times New Roman", serif;
    color: var(--color-text);
    margin-bottom: 2.5rem;
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  :global(.section-blog) {
    margin-top: 2rem;
    padding: 2rem 1rem 0.5rem 1rem;
    border-top: 2px solid var(--color-apple-green);
    background-color: var(--color-apple-green-tint);
    margin-left: -1rem;
    margin-right: -1rem;
  }

  :global(.section-opensource) {
    margin-top: 2rem;
    padding: 2rem 1rem 0.5rem 1rem;
    border-top: 2px solid var(--color-apple-yellow);
    background-color: var(--color-apple-yellow-tint);
    margin-left: -1rem;
    margin-right: -1rem;
  }

  :global(.section-writing) {
    margin-top: 2rem;
    padding: 2rem 1rem 0.5rem 1rem;
    border-top: 2px solid var(--color-apple-orange);
    background-color: var(--color-apple-orange-tint);
    margin-left: -1rem;
    margin-right: -1rem;
  }

  :global(.section-support) {
    margin-top: 2rem;
    padding: 2rem 1rem 0.5rem 1rem;
    border-top: 2px solid var(--color-apple-red);
    background-color: var(--color-apple-red-tint);
    margin-left: -1rem;
    margin-right: -1rem;
  }

  :global(.section-personal) {
    margin-top: 2rem;
    padding: 2rem 1rem 0.5rem 1rem;
    border-top: 2px solid var(--color-apple-purple);
    background-color: var(--color-apple-purple-tint);
    margin-left: -1rem;
    margin-right: -1rem;
  }

  :global(.section-blog) :global(a:hover) {
    color: var(--color-apple-green-hover);
  }

  :global(.section-opensource) :global(a:hover) {
    color: var(--color-apple-yellow-hover);
  }

  :global(.section-writing) :global(a:hover) {
    color: var(--color-apple-orange-hover);
  }

  :global(.section-support) :global(a:hover) {
    color: var(--color-apple-red);
  }

  :global(.section-personal) :global(a:hover) {
    color: var(--color-apple-purple);
  }

  main :global(h2) {
    color: var(--color-heading);
    margin: 0 0 0.75rem 0;
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: 0;
  }

  main :global(h2 + p) {
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    font-size: 0.9rem;
    margin-top: -0.5rem;
  }

  main :global(ul) {
    list-style: none;
    padding: 0;
    margin-bottom: 0;
  }

  main :global(li) {
    margin-bottom: 0.6rem;
  }

  main :global(a) {
    font-size: 0.95rem;
  }

  main :global(.project-desc) {
    margin: 0.15rem 0 0 0;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .recent-posts {
    list-style: none;
    padding: 0;
    margin: 0 0 0.5rem 0;
  }

  .recent-posts li {
    margin-bottom: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .post-date {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    margin-left: 0;
    letter-spacing: 0.05em;
    font-variant: small-caps;
  }

  .all-posts {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
  }
</style>
