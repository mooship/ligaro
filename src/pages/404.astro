---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found — Timothy Brits" robots="noindex">
  <main id="main-content" tabindex="-1">
    <h1>404</h1>
    <p>This page doesn't exist.</p>
    <nav class="links">
      <a href="/">
        <span>Home</span>
      </a>
      <a href="/blog">
        <span>Blog</span>
      </a>
    </nav>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  h1 {
    color: var(--color-heading);
    font-weight: 700;
    font-size: 4rem;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  p {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin: 0 0 1.5rem 0;
  }

  .links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .links a {
    font-size: 0.95rem;
  }
</style>
