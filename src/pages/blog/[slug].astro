---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { ArrowLeft, ArrowRight } from "@lucide/astro";
import {
  formatDate,
  getAdjacentPosts,
  getBlogPosts,
  getPostSlug,
  getReadingTime,
  getRelatedPosts,
  getSeriesPosts,
} from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => {
    const slug = getPostSlug(post.id);
    const adjacent = getAdjacentPosts(posts, slug);
    const related = getRelatedPosts(posts, post);
    const seriesPosts = post.data.series
      ? getSeriesPosts(posts, post.data.series)
      : [];
    return {
      params: { slug },
      props: { post, adjacent, related, seriesPosts },
    };
  });
}

const { post, adjacent, related, seriesPosts } = Astro.props;
const { slug } = Astro.params;
const { Content, remarkPluginFrontmatter } = await render(post);
const readingTime = getReadingTime(remarkPluginFrontmatter);
const ogImage = new URL(`/og/${slug}.png`, Astro.site).toString();
---

<Layout
  title={`${post.data.title} — Timothy Brits`}
  description={post.data.description}
  image={ogImage}
  type="article"
  datePublished={post.data.pubDate}
  dateModified={post.data.updatedDate ?? post.data.pubDate}
>
  <div class="progress-bar" aria-hidden="true"></div>
  <main id="main-content" tabindex="-1">
    <a href="/blog" class="back-link">
      <span aria-hidden="true">&larr;</span> All posts
    </a>
    <article>
      <header>
        <h1>{post.data.title}</h1>
        <time datetime={post.data.pubDate.toISOString()}>
          <span class="visually-hidden">Published: </span>
          {formatDate(post.data.pubDate)}
        </time>
        {readingTime && <span class="reading-time">{readingTime}</span>}
        {
          post.data.updatedDate && (
            <time
              class="updated"
              datetime={post.data.updatedDate.toISOString()}
            >
              Updated: {formatDate(post.data.updatedDate)}
            </time>
          )
        }
        {
          post.data.tags.length > 0 && (
            <ul class="post-tags" aria-label="Tags">
              {post.data.tags.map((tag: string) => (
                <li>
                  <a href={`/blog/tags/${tag}`} class="tag">
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </header>
      {
        seriesPosts.length > 1 && (
          <nav class="series-box" aria-label="Post series">
            <p class="series-label">
              Series: <strong>{post.data.series}</strong>
            </p>
            <ol>
              {seriesPosts.map(
                (sp: { id: string; data: { title: string } }) => {
                  const spSlug = getPostSlug(sp.id);
                  const isCurrent = sp.id === post.id;
                  return (
                    <li class={isCurrent ? "current" : ""}>
                      {isCurrent ? (
                        <span aria-current="page">{sp.data.title}</span>
                      ) : (
                        <a href={`/blog/${spSlug}`}>{sp.data.title}</a>
                      )}
                    </li>
                  );
                }
              )}
            </ol>
          </nav>
        )
      }
      <Content />
    </article>
    {
      related.length > 0 && (
        <aside class="related-posts">
          <h2>Related posts</h2>
          <ul>
            {related.map(
              (rp: { id: string; data: { title: string; pubDate: Date } }) => (
                <li>
                  <a href={`/blog/${getPostSlug(rp.id)}`}>{rp.data.title}</a>
                </li>
              )
            )}
          </ul>
        </aside>
      )
    }
    {
      (adjacent.prev || adjacent.next) && (
        <nav class="post-nav" aria-label="Post navigation">
          {adjacent.prev ? (
            <a href={`/blog/${adjacent.prev.slug}`} class="post-nav-link prev">
              <ArrowLeft size={16} aria-hidden="true" />
              <span>{adjacent.prev.title}</span>
            </a>
          ) : (
            <span />
          )}
          {adjacent.next ? (
            <a href={`/blog/${adjacent.next.slug}`} class="post-nav-link next">
              <span>{adjacent.next.title}</span>
              <ArrowRight size={16} aria-hidden="true" />
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }
  </main>
</Layout>

<script>
  let scrollAbort: AbortController | undefined;

  function initProgress() {
    scrollAbort?.abort();
    scrollAbort = new AbortController();

    const bar = document.querySelector<HTMLElement>(".progress-bar");
    if (!bar) return;

    if (globalThis.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      bar.style.display = "none";
      return;
    }

    function updateProgress() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight;
      const winHeight = window.innerHeight;
      const progress = Math.min(scrollTop / (docHeight - winHeight), 1);
      bar!.style.transform = `scaleX(${progress})`;
    }

    window.addEventListener("scroll", updateProgress, {
      passive: true,
      signal: scrollAbort.signal,
    });
    updateProgress();
  }

  initProgress();

  document.addEventListener("astro:after-swap", initProgress);

  function initCopyButtons() {
    for (const pre of document.querySelectorAll("article pre")) {
      if (pre.querySelector(".copy-btn")) continue;

      const button = document.createElement("button");
      button.className = "copy-btn";
      button.type = "button";
      button.setAttribute("aria-label", "Copy code");
      button.textContent = "Copy";

      button.addEventListener("click", async () => {
        const code = pre.querySelector("code");
        if (!code) return;

        await navigator.clipboard.writeText(code.textContent ?? "");
        button.textContent = "Copied!";
        setTimeout(() => {
          button.textContent = "Copy";
        }, 2000);
      });

      (pre as HTMLElement).style.position = "relative";
      pre.append(button);
    }
  }

  initCopyButtons();
  document.addEventListener("astro:after-swap", initCopyButtons);
</script>

<style>
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(
      to right,
      var(--color-apple-green),
      var(--color-apple-yellow),
      var(--color-apple-orange),
      var(--color-apple-red),
      var(--color-apple-purple),
      var(--color-apple-blue)
    );
    transform-origin: left;
    transform: scaleX(0);
    z-index: 9999;
    pointer-events: none;
  }

  main {
    margin: auto;
    padding-top: 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--separator);
  }

  h1 {
    font-size: 2.125rem;
    margin: 0 0 0.75rem 0;
    letter-spacing: -0.01em;
    line-height: 1.08;
  }

  time,
  .reading-time {
    display: block;
    font-size: 0.75rem;
    color: var(--secondary-label);
  }

  .updated {
    margin-top: 0.25rem;
  }

  .post-tags {
    margin-top: 0.5rem;
  }

  article :global(p) {
    margin: 0 0 1.25rem 0;
    line-height: 1.6;
  }

  article :global(h2),
  article :global(h3),
  article :global(h4) {
    color: var(--label);
    font-weight: 600;
    margin: 2.5rem 0 0.75rem 0;
    text-wrap: balance;
    letter-spacing: 0;
    line-height: 1.15;
  }

  article :global(h2) {
    font-size: 1.375rem;
  }

  article :global(h3) {
    font-size: 1.25rem;
    font-weight: 500;
  }

  article :global(h4) {
    font-size: 1.125rem;
  }

  article :global(blockquote) {
    border-left: 3px solid var(--color-apple-blue);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--secondary-label);
    font-size: 1.05rem;
    font-style: italic;
  }

  article :global(code) {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.85em;
    background: var(--secondary-system-background);
    padding: 0.2em 0.4em;
    border-radius: 6px;
  }

  article :global(pre) {
    font-family: var(--font-mono), ui-monospace, monospace;
    background: var(--secondary-system-background);
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  article :global(pre code) {
    background: none;
    padding: 0;
  }

  article :global(.copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--system-background);
    border: 1px solid var(--separator);
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-sans), system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--secondary-label);
    cursor: pointer;
    opacity: 0.6;
    transition:
      opacity 0.2s ease,
      color 0.2s ease;
  }

  article :global(pre:hover .copy-btn),
  article :global(.copy-btn:focus-visible) {
    opacity: 1;
  }

  article :global(.copy-btn:focus-visible) {
    outline: 2px solid var(--tint);
    outline-offset: 2px;
  }

  article :global(.copy-btn:hover) {
    color: var(--label);
  }

  article :global(ul),
  article :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1rem 0;
  }

  article :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.47;
  }

  article :global(hr) {
    border: none;
    height: 3px;
    background: var(--rainbow-gradient);
    background-size: 100% 100%;
    margin: 2rem 0;
  }

  .series-box {
    border: 1px solid var(--separator);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    background: var(--color-apple-green-tint);
  }

  .series-label {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--secondary-label);
    margin: 0 0 0.5rem 0;
  }

  .series-box ol {
    list-style: decimal;
    padding-left: 1.25rem;
    margin: 0;
  }

  .series-box li {
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
    color: var(--secondary-label);
  }

  .series-box li.current {
    color: var(--label);
    font-weight: 600;
  }

  .related-posts {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--separator);
  }

  .related-posts h2 {
    font-family: var(--font-sans), system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--secondary-label);
    margin: 0 0 0.75rem 0;
  }

  .related-posts ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .related-posts li {
    margin-bottom: 0.4rem;
  }

  .related-posts a {
    font-family: var(--font-sans), system-ui, sans-serif;
    font-size: 0.95rem;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--separator);
  }

  .post-nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    max-width: 48%;
  }

  .post-nav-link.next {
    margin-left: auto;
    text-align: right;
  }
</style>
