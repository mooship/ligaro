---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getBlogPosts, getPostSlug } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({
    params: { slug: getPostSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const readingTime = remarkPluginFrontmatter?.readingTime as string | undefined;
---

<Layout
  title={`${post.data.title} — Timothy Brits`}
  description={post.data.description}
  type="article"
>
  <main id="main-content" tabindex="-1">
    <a href="/blog" class="back-link">
      <span>&larr; All posts</span>
    </a>
    <article>
      <header>
        <h1>{post.data.title}</h1>
        <time datetime={post.data.pubDate.toISOString()}>
          {
            post.data.pubDate.toLocaleDateString("en-ZA", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
        {readingTime && <span class="reading-time">{readingTime}</span>}
        {
          post.data.updatedDate && (
            <time
              class="updated"
              datetime={post.data.updatedDate.toISOString()}
            >
              Updated:{" "}
              {post.data.updatedDate.toLocaleDateString("en-ZA", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          )
        }
      </header>
      <Content />
    </article>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  .back-link {
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-family: Georgia, "Times New Roman", serif;
    color: var(--color-heading);
    font-weight: 700;
    font-size: 2.5rem;
    margin: 0 0 0.75rem 0;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  time {
    display: block;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .reading-time {
    display: block;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .updated {
    margin-top: 0.25rem;
  }

  article :global(p) {
    margin: 0 0 1.25rem 0;
    line-height: 1.53;
  }

  article :global(h2),
  article :global(h3),
  article :global(h4) {
    color: var(--color-heading);
    font-weight: 700;
    margin: 2.5rem 0 0.75rem 0;
    text-wrap: balance;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  article :global(h2) {
    font-size: 1.5rem;
  }

  article :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
  }

  article :global(blockquote) {
    border-left: 4px solid var(--color-apple-blue);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    font-style: italic;
  }

  article :global(code) {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.85em;
    background: var(--color-border);
    padding: 0.2em 0.4em;
    border-radius: 6px;
  }

  article :global(pre) {
    font-family: var(--font-mono), ui-monospace, monospace;
    background: var(--color-border);
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  article :global(pre code) {
    background: none;
    padding: 0;
  }

  article :global(ul),
  article :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1rem 0;
  }

  article :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.47;
  }

  article :global(a) {
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0 1px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    transition: background-size 0.4s cubic-bezier(0, 0, 0.2, 1);
  }

  article :global(a:hover) {
    background-size: 100% 2px;
  }

  article :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
</style>
